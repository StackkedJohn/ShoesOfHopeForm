PORT=3000
NODE_ENV=development

# Supabase — required for writing to the submissions table
# Use the SERVICE ROLE key (server-side only, never exposed to the browser).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Optional: anon key (only if a browser-side read is added in the future)
SUPABASE_ANON_KEY=your_anon_key_here

# Resend — confirmation email on submit
RESEND_API_KEY=your_resend_api_key_here

# Mapbox — caregiver address autocomplete + county lookup
# Get these from https://account.mapbox.com/ (same tokens used by LOTCFORM)
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here
MAPBOX_ADDRESS_TOKEN=your_mapbox_address_token_here

# Match the SUPABASE_URL / Vercel naming for parity with other LOTC projects.
# These two are also accepted as aliases by some helpers — uncomment if you
# want the public Supabase URL exposed for client-side reads later.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
